{% extends 'base.html.twig' %}

{% block stylesheets %}
	<style>
		.stroke{
			text-decoration: line-through;
			color: #ccc;
			font-style: italic;
		}
	</style>
{% endblock %}

{% block title %}
	Liste tâches
{% endblock %}

{% block body %}
	<h1>Toutes les tâches</h1>

	{{form_start(form, {attr: {'class': 'd-flex align-items-center gap-3'}})}}
	{{form_row(form.title)}}
	{{form_row(form.category)}}
		<button style="color: green" class="btn p-0 m-0">
			<i class="bi bi-plus-circle-fill fs-1"></i>
		</button>
	{{form_end(form)}}
	
	<hr>
		{% for task in tasks %}
			<div>
				<div class="d-flex align-items-start gap-5">
                    <h2 class="d-flex align-items-start gap-2">
					    <span class="{{task.isDone?'stroke':''}}">
							{{task.title}}
						</span> 
						<span class="badge rounded-pill text-bg-warning fs-6 fst-italic">
							{{task.category.name}}
						</span>						
				    </h2>

                    <form action="{{path('task_delete')}}" 
                          method="POST"
                          onsubmit="return confirm('Supprimer??')"
                          >
                        <input type="hidden" name="id" value="{{task.id}}">
                        <button class="p-0 text-danger fs-3 btn">
							<i class="bi bi-trash-fill"></i>
						</button>
                    </form>
                </div>

				<form action="{{path('task_complete')}}" method="POST">
					<input type="hidden" name="id" value="{{task.id}}">
					
					<div class="form-check form-switch">
						<input {{task.isDone?'checked':''}} onchange="submit()" class="form-check-input" type="checkbox" >
					</div>
				</form>
				<small>Créé le
					{{task.createdAt | date('d/m/Y H:i:s')}}
				</small>
			</div>
			<hr>
		{% endfor %}

	{% endblock %}
